#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>
#include <math.h>

// ================= PCA9685 =================

Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver(0x40);

const int SERVO1_CH = 3;   // pointer
const int SERVO2_CH = 1;   // ring
const int SERVO3_CH = 2;   // middle
const int SERVO4_CH = 0;   // pinky

// servo constraints
const int SERVO_MIN_US = 1000;
const int SERVO_MAX_US = 2000;

// ================= sensors =================

// pointer
float pq1, voltage1;
float pq1Min, pq1Max;

// ring
float pq2, voltage2;
float pq2Min, pq2Max;

// middle
float pq3, voltage3;
float pq3Min, pq3Max;

// pinky
float pq4, voltage4;
float pq4Min, pq4Max;

// ================= buttons =================

const int btn12 = 12;   // record / delete
const int btn13 = 13;   // playback
const float ADC_TO_V = 5.0 / 1023.0;

// ================= recording =================

struct PositionRecord {
  int pulse1;
  int pulse2;
  int pulse3;
  int pulse4;
};

PositionRecord storedRecord;
bool hasStoredRecord = false;

// button state + timing for long press
bool lastBtn12Reading = HIGH;
bool lastBtn13Reading = HIGH;

unsigned long btn12PressTime = 0;
const unsigned long longPressThreshold = 800; // ms

// playback state
bool playbackActive = false;
const unsigned long playbackHoldTime = 2500; // ms

// =====================================================
// Utility functions
// =====================================================

float readVoltage(int pin) {
  return analogRead(pin) * ADC_TO_V;
}

int mapVoltageToPulse(float v, float vMin, float vMax) {

  // guard against bad calibration
  if (fabs(vMax - vMin) < 0.01) {
    return 1500;
  }

  v = constrain(v, vMin, vMax);

  long v_int    = (long)(v * 1000);
  long vMin_int = (long)(vMin * 1000);
  long vMax_int = (long)(vMax * 1000);

  return map(v_int,
             vMin_int,
             vMax_int,
             SERVO_MIN_US,
             SERVO_MAX_US);
}

// =====================================================
// PCA9685 servo output
// =====================================================

void writeServoUS(uint8_t channel, int microseconds) {

  microseconds = constrain(
      microseconds,
      SERVO_MIN_US,
      SERVO_MAX_US);

  // 50 Hz = 20,000 us period
  uint16_t ticks = (uint32_t)microseconds * 4096UL / 20000UL;

  pwm.setPWM(channel, 0, ticks);
}

// =====================================================
// Calibration
// =====================================================

void calibratePQInputs() {

  pq1Min = 5.0;
  pq1Max = 0.0;

  pq2Min = 5.0;
  pq2Max = 0.0;

  pq3Min = 5.0;
  pq3Max = 0.0;

  pq4Min = 5.0;
  pq4Max = 0.0;

  Serial.println("Calibrating for 10 seconds...");

  unsigned long startTime = millis();

  while (millis() - startTime < 10000) {

    float v1 = readVoltage(A1);
    float v2 = readVoltage(A3);
    float v3 = readVoltage(A2);
    float v4 = readVoltage(A0);

    if (v1 < pq1Min) pq1Min = v1;
    if (v1 > pq1Max) pq1Max = v1;

    if (v2 < pq2Min) pq2Min = v2;
    if (v2 > pq2Max) pq2Max = v2;

    if (v3 < pq3Min) pq3Min = v3;
    if (v3 > pq3Max) pq3Max = v3;

    if (v4 < pq4Min) pq4Min = v4;
    if (v4 > pq4Max) pq4Max = v4;

    delay(10);
  }

  Serial.println("Calibration done");

  Serial.print("pq1 min/max: ");
  Serial.print(pq1Min);
  Serial.print(" / ");
  Serial.println(pq1Max);

  Serial.print("pq2 min/max: ");
  Serial.print(pq2Min);
  Serial.print(" / ");
  Serial.println(pq2Max);

  Serial.print("pq3 min/max: ");
  Serial.print(pq3Min);
  Serial.print(" / ");
  Serial.println(pq3Max);

  Serial.print("pq4 min/max: ");
  Serial.print(pq4Min);
  Serial.print(" / ");
  Serial.println(pq4Max);
}

// =====================================================
// Servo control
// =====================================================

void updateServosFromInputs() {

  float v1 = readVoltage(A1);
  float v2 = readVoltage(A3);
  float v3 = readVoltage(A2);
  float v4 = readVoltage(A0);

  int p1 = mapVoltageToPulse(v1, pq1Min, pq1Max);
  int p2 = mapVoltageToPulse(v2, pq2Min, pq2Max);
  int p3 = mapVoltageToPulse(v3, pq3Min, pq3Max);
  int p4 = mapVoltageToPulse(v4, pq4Min, pq4Max);

  writeServoUS(SERVO1_CH, p1);
  writeServoUS(SERVO2_CH, p2);
  writeServoUS(SERVO3_CH, p3);
  writeServoUS(SERVO4_CH, p4);
}

// =====================================================
// Recording
// =====================================================

void captureCurrentServoState(PositionRecord &record) {

  float v1 = readVoltage(A1);
  float v2 = readVoltage(A3);
  float v3 = readVoltage(A2);
  float v4 = readVoltage(A0);

  record.pulse1 = mapVoltageToPulse(v1, pq1Min, pq1Max);
  record.pulse2 = mapVoltageToPulse(v2, pq2Min, pq2Max);
  record.pulse3 = mapVoltageToPulse(v3, pq3Min, pq3Max);
  record.pulse4 = mapVoltageToPulse(v4, pq4Min, pq4Max);
}

void recordCurrentPosition() {

  captureCurrentServoState(storedRecord);
  hasStoredRecord = true;

  Serial.println("Position recorded:");

  Serial.print("p1: ");
  Serial.print(storedRecord.pulse1);

  Serial.print("  p2: ");
  Serial.print(storedRecord.pulse2);

  Serial.print("  p3: ");
  Serial.print(storedRecord.pulse3);

  Serial.print("  p4: ");
  Serial.println(storedRecord.pulse4);
}

void deleteStoredPosition() {

  hasStoredRecord = false;
  Serial.println("Stored position deleted");
}

// =====================================================
// Playback
// =====================================================

void playbackStoredPosition() {

  if (!hasStoredRecord) {
    Serial.println("No stored position to playback");
    return;
  }

  Serial.println("Playback stored position:");

  Serial.print("p1: ");
  Serial.print(storedRecord.pulse1);

  Serial.print("  p2: ");
  Serial.print(storedRecord.pulse2);

  Serial.print("  p3: ");
  Serial.print(storedRecord.pulse3);

  Serial.print("  p4: ");
  Serial.println(storedRecord.pulse4);

  writeServoUS(SERVO1_CH, storedRecord.pulse1);
  writeServoUS(SERVO2_CH, storedRecord.pulse2);
  writeServoUS(SERVO3_CH, storedRecord.pulse3);
  writeServoUS(SERVO4_CH, storedRecord.pulse4);

  playbackActive = true;
}

// =====================================================
// Setup
// =====================================================

void setup() {

  Serial.begin(9600);

  pinMode(btn12, INPUT_PULLUP);
  pinMode(btn13, INPUT_PULLUP);

  Wire.begin();          // A4 = SDA, A5 = SCL

  pwm.begin();
  pwm.setPWMFreq(50);    // standard servo frequency

  delay(100);

  // neutral startup position
  writeServoUS(SERVO1_CH, 1500);
  writeServoUS(SERVO2_CH, 1500);
  writeServoUS(SERVO3_CH, 1500);
  writeServoUS(SERVO4_CH, 1500);

  calibratePQInputs();
}

// =====================================================
// Main loop
// =====================================================

void loop() {

  unsigned long now = millis();

  bool btn12Reading = digitalRead(btn12);
  bool btn13Reading = digitalRead(btn13);

  // ----- button 12 -----
  if (btn12Reading == LOW &&
      lastBtn12Reading == HIGH) {

    btn12PressTime = now;
  }

  if (btn12Reading == HIGH &&
      lastBtn12Reading == LOW) {

    unsigned long pressDuration =
        now - btn12PressTime;

    if (pressDuration >= longPressThreshold) {
      deleteStoredPosition();
    }
    else {
      recordCurrentPosition();
    }
  }

  lastBtn12Reading = btn12Reading;

  // ----- button 13 -----
  if (btn13Reading == LOW &&
      lastBtn13Reading == HIGH) {

    playbackStoredPosition();

    delay(playbackHoldTime);

    playbackActive = false;
  }

  lastBtn13Reading = btn13Reading;

  // teleoperation mode
  if (!playbackActive) {
    updateServosFromInputs();
  }

  delay(20);
}