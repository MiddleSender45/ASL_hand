import ollama
import serial
import time

# =========================
# SERIAL SETUP
# =========================
arduino = serial.Serial('COM6', 9600, timeout=1)
time.sleep(2)  # allow Arduino reset

# =========================
# SYSTEM PROMPT
# =========================
SYSTEM_PROMPT = """
You are an AI assistant for people who are hard of hearing.

You receive instructions describing what the user needs.

RULES:
- Respond with extremely short output (1-3 words preferred).
- Every word will be converted into robotic sign language.
- Do NOT explain anything.
- Do NOT add filler phrases.
- NEVER use any word containing the letters J or Z (uppercase or lowercase).
- Output only the final response text.
- Do NOT say the word "Processing"
- NEVER use numbers, punctuation, or special characters in your output.
"""

# =========================
# HARD FILTER (CRITICAL)
# =========================
def valid_word(word):
    w = word.lower()
    return ('j' not in w) and ('z' not in w)

def clean_text(text):
    # keep only letters + space
    text = ''.join(c for c in text if c.isalpha() or c == ' ')
    words = text.upper().split()

    # enforce J/Z rule
    words = [w for w in words if valid_word(w)]

    return " ".join(words).strip()

# =========================
# MAIN LOOP
# =========================
while True:
    user = input("You: ")

    response = ollama.chat(
        model='gemma3:4b',
        messages=[
            {'role': 'system', 'content': SYSTEM_PROMPT},
            {'role': 'user', 'content': user}
        ]
    )

    text = response['message']['content']
    print("RAW:", text)

    # cleanup + enforce rules
    text = clean_text(text)

    # final safety fallback
    if len(text) == 0:
        text = "OK"

    # optional: limit word count hard cap
    text = " ".join(text.split()[:3])

    print("SEND:", text)

    # send to Arduino
    arduino.reset_input_buffer()
    arduino.write((text + '\n').encode('utf-8'))
    arduino.flush()